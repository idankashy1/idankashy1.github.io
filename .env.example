# Copy this file to `.env.local` and fill in your values.
# Vite only exposes vars prefixed with `VITE_` to the frontend bundle.

# URL of the Cloudflare Worker that proxies chat requests to Anthropic.
# Leave unset to fall back to the static keyword-matching chat.
# See worker/README.md for how to deploy the Worker.
# Example:
# VITE_CHAT_API_URL=https://idan-portfolio-chat.your-username.workers.dev
